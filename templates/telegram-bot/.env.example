# Standalone Telegram bot — minimal config. Copy to `.env` in this folder.
# Only these keys are needed; the bot runs the whole pipeline in-process.

# From @BotFather (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# LLM (any LiteLLM model string) + its provider key
LLM_MODEL=openai/gpt-4o
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=          # for LLM_MODEL=anthropic/claude-sonnet-4-6
# Local instead? LLM_MODEL=ollama/llama3.2 and LLM_API_BASE=http://localhost:11434

# Web search tool
TAVILY_API_KEY=

# Optional: quick | standard | deep  (default standard)
# RESEARCH_DEPTH=standard
