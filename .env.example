# ──────────────────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────────────────
APP_ENV=local                 # local | staging | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ──────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL + pgvector)
# Two URLs on purpose:
#   - ASYNC: used by the FastAPI app / SQLModel (asyncpg driver)
#   - SYNC : used by LangGraph's PostgresSaver checkpointer (psycopg driver)
# Both point at the SAME database.
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@localhost:5432/research
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/research

# ──────────────────────────────────────────────────────────────────────────
# Redis (Celery broker + backend AND Pub/Sub event bus)
# ──────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────────────────────
# Default LLM (model-agnostic via LiteLLM model strings)
# Cloud example:  LLM_MODEL=openai/gpt-4o          (set LLM_API_KEY or OPENAI_API_KEY)
#                 LLM_MODEL=anthropic/claude-sonnet-4-6
# Local example:  LLM_MODEL=ollama/llama3.2        + LLM_API_BASE=http://localhost:11434
# ──────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=litellm
LLM_MODEL=openai/gpt-4o
LLM_API_BASE=
LLM_API_KEY=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Per-agent model overrides (unset -> LLM_MODEL). Planner/Critic make small
# structured-JSON calls and run fine on a cheaper, faster model than the
# Synthesizer, which writes the whole report.
LLM_MODEL_PLANNER=
LLM_MODEL_RESEARCHER=
LLM_MODEL_CRITIC=
LLM_MODEL_SYNTHESIZER=

# Provider keys (LiteLLM also reads these from env automatically by convention)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Telegram (only for the standalone bot template — templates/telegram-bot/)
# ──────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Tools
# ──────────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=
ARXIV_MIN_INTERVAL_SECONDS=3.0   # arxiv asks ~1 req / 3s

# ──────────────────────────────────────────────────────────────────────────
# Security
#   API_AUTH_ENABLED=true  → routes require  Authorization: Bearer <key>
#                            (issue one: python -m research_assistant.scripts.issue_api_key <user_id>)
#   API_AUTH_ENABLED=false → open API, every request maps to API_DEV_PRINCIPAL
#   API_ENCRYPTION_KEY     → Fernet key; encrypts Telegram bot tokens at rest.
#                            Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ──────────────────────────────────────────────────────────────────────────
API_AUTH_ENABLED=true
API_DEV_PRINCIPAL=local-dev
API_ENCRYPTION_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Pipeline tuning
# ──────────────────────────────────────────────────────────────────────────
MAX_REVISIONS=2                  # cap critic -> researcher re-loops
TASK_TIME_LIMIT_SECONDS=600      # Celery hard time limit (10 min)
TASK_PENDING_TIMEOUT_SECONDS=300 # pending task never picked up -> failed on read (0 = off)
EMBEDDING_DIM=1536               # pgvector column width (unused by MVP, reserved)
